{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Biome: Check",
      "type": "shell",
      "command": "bun run lint",
      "problemMatcher": ["$biome"],
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Biome: Fix",
      "type": "shell",
      "command": "bun run lint:fix",
      "problemMatcher": ["$biome"]
    }
  ]
}
